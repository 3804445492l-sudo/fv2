    local function FindAimPart(model)
        local pref = Options.AimPartDrop.Value
        local p = model:FindFirstChild(pref)
        if p and p:IsA("BasePart") then return p end
        for _, n in ipairs({"Head", "HumanoidRootPart", "UpperTorso", "Torso"}) do
            local f = model:FindFirstChild(n)
            if f and f:IsA("BasePart") then return f end
        end
        return nil
    end

    local function IsAimValid(model)
        if not model or not model.Parent then return false end
        local hum = model:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return false end
        local part = FindAimPart(model)
        if not part then return false end
        local _, myRoot = GetCharParts()
        if not myRoot then return false end
        if (part.Position - myRoot.Position).Magnitude > Options.AimMaxDist.Value then return false end
        return true
    end

    local function GetAimTargets()
        local res = {}
        local myChar = LocalPlayer.Character
        for _, pl in pairs(Players:GetPlayers()) do
            if pl ~= LocalPlayer and pl.Character then
                local c = pl.Character
                local hum = c:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    local part = FindAimPart(c)
                    if part then
                        local skip = false
                        if Toggles.AimTeamCheck.Value and LocalPlayer.Team and pl.Team == LocalPlayer.Team then skip = true end
                        if not skip then
                            table.insert(res, {model = c, name = pl.Name, part = part})
                        end
                    end
                end
            end
        end
        -- 也扫描非玩家NPC
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj ~= myChar then
                local isPlayer = false
                for _, pl in pairs(Players:GetPlayers()) do
                    if pl.Character == obj then isPlayer = true break end
                end
                if not isPlayer then
                    local hum = obj:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 then
                        local part = FindAimPart(obj)
                        if part then
                            table.insert(res, {model = obj, name = obj.Name, part = part})
                        end
                    end
                end
            end
        end
        return res
    end

    SafeConnect(RunService.RenderStepped, function()
        local aimOn = Toggles.AimOn.Value
        if not aimOn then
            _G._AimLocked = nil
            aimPrevName = nil
            LkL.Text = "目标: 无" DsL.Text = "距离: --" HpL.Text = "血量: --"
            return
        end

        local aiming = Options.AimKey:GetState()
        if not aiming then
            if not Toggles.AimStickyLock.Value then
                _G._AimLocked = nil
                aimPrevName = nil
            end
            LkL.Text = "目标: 无" DsL.Text = "距离: --" HpL.Text = "血量: --"
            return
        end

        local _, myRoot = GetCharParts()
        if not myRoot then return end

        -- 检查当前锁定是否还有效
        if _G._AimLocked and not IsAimValid(_G._AimLocked) then
            _G._AimLocked = nil
        end

        -- 如果没有锁定目标，搜索新目标
        if not _G._AimLocked then
            local targets = GetAimTargets()
            local maxD = Options.AimMaxDist.Value
            local fovR = Options.AimFov.Value
            local prio = Options.AimPriority.Value
            local best, bScore, bName = nil, math.huge, ""
            local vp = Camera.ViewportSize
            local sc = Vector2.new(vp.X / 2, vp.Y / 2)

            for _, d in ipairs(targets) do
                local part = d.part
                if not part or not part.Parent then continue end
                local wDist = (part.Position - myRoot.Position).Magnitude
                if wDist > maxD then continue end

                if prio == "离我最近" then
                    if wDist < fovR and wDist < bScore then
                        bScore = wDist
                        best = d.model
                        bName = d.name
                    end
                else
                    local sPos, onS = Camera:WorldToViewportPoint(part.Position)
                    if onS then
                        local sDist = (Vector2.new(sPos.X, sPos.Y) - sc).Magnitude
                        if sDist < bScore then
                            bScore = sDist
                            best = d.model
                            bName = d.name
                        end
                    end
                end
            end

            if best then
                _G._AimLocked = best
                if bName ~= aimPrevName and Toggles.AimNotify.Value then
                    Library:Notify("🎯 锁定: " .. bName, 2)
                end
                aimPrevName = bName
            end
        end

        if not _G._AimLocked then
            LkL.Text = "目标: 无" DsL.Text = "距离: --" HpL.Text = "血量: --"
            return
        end

        local part = FindAimPart(_G._AimLocked)
        if not part then
            _G._AimLocked = nil
            return
        end

        -- 获取目标名字
        local tName = _G._AimLocked.Name
        for _, pl in pairs(Players:GetPlayers()) do
            if pl.Character == _G._AimLocked then tName = pl.Name break end
        end

        -- 计算瞄准位置（含预判）
        local aimPos = part.Position
        if Options.AimPred.Value > 0 then
            local bRoot = _G._AimLocked:FindFirstChild("HumanoidRootPart")
            local vel = Vector3.zero
            if bRoot then vel = bRoot.AssemblyLinearVelocity
            elseif part then vel = part.AssemblyLinearVelocity end
            if vel.Magnitude > 0.1 then
                aimPos = aimPos + vel * (Options.AimPred.Value / 100)
            end
        end

        -- ★★★ 核心：直接转动镜头，把屏幕中心（准星）对准目标 ★★★
        local sm = Options.AimSmooth.Value
        local camPos = Camera.CFrame.Position
        local dir = (aimPos - camPos)

        if dir.Magnitude > 0.01 then
            -- 目标方向
            local targetCF = CFrame.lookAt(camPos, aimPos)
            -- 当前朝向
            local currentCF = Camera.CFrame

            -- 平滑插值：sm越小越快，1=瞬间锁定
            local alpha = math.clamp(1 / sm, 0.01, 1)
            local newCF = currentCF:Lerp(CFrame.new(camPos) * (CFrame.new(camPos):Inverse() * targetCF), alpha)
            -- 保持相机位置不变，只改朝向
            Camera.CFrame = CFrame.new(camPos) * (CFrame.new():Inverse() * CFrame.fromMatrix(Vector3.zero, newCF.RightVector, newCF.UpVector, -newCF.LookVector))
        end

        -- 更新信息面板
        local wD = (aimPos - myRoot.Position).Magnitude
        LkL.Text = "目标: " .. tName
        DsL.Text = "距离: " .. math.floor(wD) .. "m"
        local h2 = _G._AimLocked:FindFirstChildOfClass("Humanoid")
        if h2 then HpL.Text = "血量: " .. math.floor(h2.Health) .. "/" .. math.floor(h2.MaxHealth) end
    end)

