    local FV, FSp, FMa, FFr, FRa = 3e4, 5e3, 9999, 80, 2
    FlingSetBox:AddSlider("FVS", {Text = "力度", Default = 30000, Min = 5000, Max = 80000, Rounding = 0, Callback = function(v) FV = v end})
    FlingSetBox:AddSlider("FSS", {Text = "旋转", Default = 5000, Min = 500, Max = 20000, Rounding = 0, Callback = function(v) FSp = v end})
    FlingSetBox:AddSlider("FFS", {Text = "频率", Default = 80, Min = 10, Max = 200, Rounding = 0, Callback = function(v) FFr = v end})
    FlingSetBox:AddSlider("FMS", {Text = "质量", Default = 9999, Min = 100, Max = 99999, Rounding = 0, Callback = function(v) FMa = v end})
    FlingSetBox:AddSlider("FRS", {Text = "范围", Default = 2, Min = 1, Max = 5, Rounding = 1, Callback = function(v) FRa = v end})

    local FS = {Active = false, Conn = nil, OPos = nil}
    local function CFP() local char = LocalPlayer.Character if not char then return end for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = true v.AssemblyLinearVelocity = Vector3.zero v.AssemblyAngularVelocity = Vector3.zero v.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5) end end end

    local function EndFling()
        FS.Active = false
        if FS.Conn then FS.Conn:Disconnect() FS.Conn = nil end
        local char, root, hum = GetCharParts()
        if not char then return end
        CFP()
        if hum then hum.PlatformStand = false hum.AutoRotate = true pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end) end
        if root then root.Velocity = Vector3.zero root.RotVelocity = Vector3.zero root.AssemblyLinearVelocity = Vector3.zero root.AssemblyAngularVelocity = Vector3.zero task.wait(0.1) if FS.OPos then root.CFrame = FS.OPos FS.OPos = nil end end
        if hum then Camera.CameraSubject = hum end
        Library:Notify("✅ 甩飞结束", 2)
    end

    local function FlingLogic(TN2, Mode)
        if FS.Active then EndFling() task.wait(0.2) end
        local Tgt = Players:FindFirstChild(TN2)
        if not Tgt or not Tgt.Character or not Tgt.Character:FindFirstChild("HumanoidRootPart") then Library:Notify("❌ 目标无效", 2) return end
        local mc, mr, mh = GetCharParts()
        if not mc or not mr or not mh then return end
        FS.OPos = mr.CFrame FS.Active = true
        Library:Notify("🚀 甩飞: " .. TN2, 3)
        mh.PlatformStand = true mh.AutoRotate = false
        for _, part in pairs(mc:GetDescendants()) do if part:IsA("BasePart") then local n = part.Name:lower() if n:find("leg") or n:find("foot") then part.CanCollide = false else part.CanCollide = true end part.CustomPhysicalProperties = PhysicalProperties.new(FMa, 0.3, 0.5) end end
        local t0 = 0
        FS.Conn = RunService.Heartbeat:Connect(function(dt)
            if not FS.Active then return end
            if not Tgt or not Tgt.Parent or not Tgt.Character then EndFling() return end
            local tR = Tgt.Character:FindFirstChild("HumanoidRootPart")
            local tH = Tgt.Character:FindFirstChildOfClass("Humanoid")
            if not tR then EndFling() return end
            if tH and tH.Health <= 0 then EndFling() return end
            if not mr or not mr.Parent then EndFling() return end
            if FS.OPos and (tR.Position - FS.OPos.Position).Magnitude > 800 then EndFling() return end
            t0 = t0 + dt
            mr.CFrame = tR.CFrame * CFrame.new(math.sin(t0 * FFr) * FRa, math.cos(t0 * FFr * 0.8) * FRa * 0.7, math.cos(t0 * FFr) * FRa)
            mr.AssemblyLinearVelocity = Vector3.new(math.sin(t0 * FFr) * FV, math.cos(t0 * FFr * 0.6) * FV * 0.5, math.cos(t0 * FFr) * FV)
            mr.AssemblyAngularVelocity = Vector3.new(math.sin(t0 * 30) * FSp, math.cos(t0 * 35) * FSp, math.sin(t0 * 40) * FSp)
            mr.Velocity = mr.AssemblyLinearVelocity mr.RotVelocity = mr.AssemblyAngularVelocity
            if mr.Position.Y < -100 then EndFling() end
        end)
        if Mode == "Once" then task.delay(1.5, function() if FS.Active then EndFling() end end)
        elseif Mode == "T5" then task.delay(5, function() if FS.Active then EndFling() end end)
        elseif Mode == "T10" then task.delay(10, function() if FS.Active then EndFling() end end) end
    end

