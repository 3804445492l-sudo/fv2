-- ==================== 修复12: 反减速用更高频方式 + 属性变更监听 ====================
local _antiSlowConns = {}

local function SetupAntiSlowdown(hum)
    -- 清除旧连接
    for _, c in pairs(_antiSlowConns) do
        pcall(function() c:Disconnect() end)
    end
    _antiSlowConns = {}

    if not AntiSlowdownEnabled then return end

    -- 监听WalkSpeed变更
    local c1 = hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if AntiSlowdownEnabled and hum.WalkSpeed < AntiSlowMinSpeed then
            hum.WalkSpeed = AntiSlowMinSpeed
        end
    end)
    table.insert(_antiSlowConns, c1)
    table.insert(AllConnections, c1)

    -- 监听JumpPower变更
    local c2 = hum:GetPropertyChangedSignal("JumpPower"):Connect(function()
        if AntiSlowdownEnabled and hum.JumpPower < AntiSlowMinJump then
            hum.JumpPower = AntiSlowMinJump
        end
    end)
    table.insert(_antiSlowConns, c2)
    table.insert(AllConnections, c2)

    -- 监听JumpHeight变更 (R15)
    local c3 = hum:GetPropertyChangedSignal("JumpHeight"):Connect(function()
        if AntiSlowdownEnabled and hum.JumpHeight < 7.2 then
            hum.JumpHeight = 7.2
        end
    end)
    table.insert(_antiSlowConns, c3)
    table.insert(AllConnections, c3)
end

-- 初始设置
task.spawn(function()
    task.wait(0.5)
    local _, _, hum = GetCharParts()
    if hum then SetupAntiSlowdown(hum) end
end)

SafeConnect(RunService.Heartbeat, function(dt)
    local char, root, hum = GetCharParts()
    if not char or not root or not hum then return end

    -- 监视模式
    if MonitorEnabled then
        monCD = monCD + dt
        if monCD >= 0.1 then
            monCD = 0
            if FlingTargetName then
                local tg = Players:FindFirstChild(FlingTargetName)
                if tg and tg.Character and tg.Character:FindFirstChild("Humanoid") then
                    Camera.CameraSubject = tg.Character.Humanoid
                end
            end
            hum.WalkSpeed = 0
            hum.JumpPower = 0
        end
        return
    end

    -- 速度
    if hum.MoveDirection.Magnitude > 0 then
        if SpeedEnabled then
            root.AssemblyLinearVelocity = Vector3.new(
                hum.MoveDirection.X * SpeedValue,
                root.AssemblyLinearVelocity.Y,
                hum.MoveDirection.Z * SpeedValue
            )
        elseif SuperEnabled then
            root.CFrame = root.CFrame + (hum.MoveDirection * (dt * 60 * MultiValue))
            root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
        end
    end

    -- 无限跳 (PC端按键检测)
    if InfJumpEnabled and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        pcall(function() hum:ChangeState(Enum.HumanoidStateType.Jumping) end)
    end

    -- 穿墙
    if NoclipEnabled then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = false
            end
        end
    end

    -- 防掉虚空
    if AntiVoidEnabled then
        if root.Position.Y < -50 then
            if lastVY then
                root.CFrame = lastVY
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            else
                -- 没有保存位置，传送到安全位置
                root.CFrame = CFrame.new(0, 50, 0)
                root.AssemblyLinearVelocity = Vector3.zero
            end
        else
            lastVY = root.CFrame
        end
    end

    -- 反减速 (Heartbeat层面的备用)
    if AntiSlowdownEnabled then
        if hum.WalkSpeed < AntiSlowMinSpeed then hum.WalkSpeed = AntiSlowMinSpeed end
        if hum.JumpPower < AntiSlowMinJump then hum.JumpPower = AntiSlowMinJump end
    end
end)

-- ==================== 修复13: 角色重生后重新应用所有状态 ====================
SafeConnect(LocalPlayer.CharacterAdded, function(char)
    task.wait(1)

    -- 防虚空位置重置
    lastVY = nil
    local root = char:FindFirstChild("HumanoidRootPart")
    if root and root.Position.Y > -50 then
        lastVY = root.CFrame
    end

    -- 甩飞重置
    if FS.Active then
        FS.Active = false
        if FS.Conn then FS.Conn:Disconnect(); FS.Conn = nil end
        FS.OPos = nil
    end

    -- 重新设置反减速监听
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and AntiSlowdownEnabled then
        SetupAntiSlowdown(hum)
    end

    -- 重新设置相机
    if hum then
        Camera.CameraSubject = hum
    end

    -- 视野锁定
    if FovLockEnabled then
        Camera.FieldOfView = FovValue
    end
end)

