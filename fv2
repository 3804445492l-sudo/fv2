-- ==================== 修复9: 甩飞结束后稳定恢复 ====================
local function EndFling()
    if not FS.Active and not FS.Conn then return end
    FS.Active = false
    if FS.Conn then
        FS.Conn:Disconnect()
        FS.Conn = nil
    end
    local char, root, hum = GetCharParts()
    if not char then return end
    CFP()
    if hum then
        hum.PlatformStand = false
        hum.AutoRotate = true
        pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
    end
    if root then
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        root.Velocity = Vector3.zero
        root.RotVelocity = Vector3.zero
        if FS.OPos then
            -- 等一帧让物理稳定
            task.wait(0.15)
            if root and root.Parent then
                root.CFrame = FS.OPos + Vector3.new(0, 3, 0) -- 稍微抬高防卡地下
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            end
            FS.OPos = nil
        end
        -- 再等一下确保稳定
        task.wait(0.1)
        if root and root.Parent then
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
        end
    end
    if hum then Camera.CameraSubject = hum end
    WindUI:Notify({Title = "甩飞", Content = "甩飞结束", Duration = 2})
end

local LoopFlingEnabled = false

local function FlingLogic(TN2, Mode)
    if FS.Active then
        EndFling()
        task.wait(0.5)
    end
    local Tgt = Players:FindFirstChild(TN2)
    if not Tgt or not Tgt.Character or not Tgt.Character:FindFirstChild("HumanoidRootPart") then
        WindUI:Notify({Title = "甩飞", Content = "目标无效", Duration = 2})
        return
    end
    local mc, mr, mh = GetCharParts()
    if not mc or not mr or not mh then return end
    FS.OPos = mr.CFrame
    FS.Active = true
    WindUI:Notify({Title = "甩飞", Content = "甩飞: " .. TN2, Duration = 3})
    mh.PlatformStand = true
    mh.AutoRotate = false
    for _, part in pairs(mc:GetDescendants()) do
        if part:IsA("BasePart") then
            local n = part.Name:lower()
            if n:find("leg") or n:find("foot") then
                part.CanCollide = false
            else
                part.CanCollide = true
            end
            part.CustomPhysicalProperties = PhysicalProperties.new(FMa, 0.3, 0.5)
        end
    end
    local t0 = 0
    FS.Conn = RunService.Heartbeat:Connect(function(dt)
        if not FS.Active then return end
        if not Tgt or not Tgt.Parent or not Tgt.Character then
            EndFling()
            return
        end
        local tR = Tgt.Character:FindFirstChild("HumanoidRootPart")
        local tH = Tgt.Character:FindFirstChildOfClass("Humanoid")
        if not tR or (tH and tH.Health <= 0) or not mr or not mr.Parent then
            EndFling()
            return
        end
        if FS.OPos and (tR.Position - FS.OPos.Position).Magnitude > 1000 then
            EndFling()
            return
        end
        t0 = t0 + dt
        mr.CFrame = tR.CFrame * CFrame.new(
            math.sin(t0 * FFr) * FRa,
            math.cos(t0 * FFr * 0.8) * FRa * 0.7,
            math.cos(t0 * FFr) * FRa
        )
        mr.AssemblyLinearVelocity = Vector3.new(
            math.sin(t0 * FFr) * FV,
            math.cos(t0 * FFr * 0.6) * FV * 0.5,
            math.cos(t0 * FFr) * FV
        )
        mr.AssemblyAngularVelocity = Vector3.new(
            math.sin(t0 * 30) * FSp,
            math.cos(t0 * 35) * FSp,
            math.sin(t0 * 40) * FSp
        )
        mr.Velocity = mr.AssemblyLinearVelocity
        mr.RotVelocity = mr.AssemblyAngularVelocity
        if mr.Position.Y < -200 then
            EndFling()
        end
    end)

    if Mode == "Once" then
        task.delay(1.5, function()
            if FS.Active then EndFling() end
        end)
    elseif Mode == "T5" then
        task.delay(5, function()
            if FS.Active then EndFling() end
        end)
    elseif Mode == "T10" then
        task.delay(10, function()
            if FS.Active then EndFling() end
        end)
    elseif Mode == "Loop" then
        task.spawn(function()
            while LoopFlingEnabled and FS.Active do
                task.wait(0.1)
            end
            if not LoopFlingEnabled and FS.Active then
                EndFling()
            end
            task.wait(1)
            if LoopFlingEnabled and FlingTargetName then
                local tg = Players:FindFirstChild(FlingTargetName)
                if tg and tg.Character and tg.Character:FindFirstChild("HumanoidRootPart") then
                    FlingLogic(FlingTargetName, "Loop")
                end
            end
        end)
    end
end

