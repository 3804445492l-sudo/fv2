local function CreateMobileButton(Name, Callback)
    if not IsMobile then return end
    local sg = nil
    local container = gethui and gethui() or CoreGui
    for _, g in pairs(container:GetChildren()) do
        if g:IsA("ScreenGui") and g.Name == "FGMobile" then
            sg = g
            break
        end
    end
    if not sg then
        sg = Instance.new("ScreenGui")
        sg.Name = "FGMobile"
        sg.ResetOnSpawn = false
        sg.Parent = container
    end
    local btnCount = #sg:GetChildren()
    local MBtn = Instance.new("TextButton", sg)
    MBtn.Size = UDim2.new(0, 50, 0, 50)
    MBtn.Position = UDim2.new(0.9, -60, 0.5, btnCount * 60)
    MBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    MBtn.BackgroundTransparency = 0.5
    MBtn.Text = Name
    MBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
