-- 用属性变更监听+RenderStepped双重拦截，游戏无法覆盖

local _savedMouseIcon = true
local _savedCameraMinZoom = nil
local _savedCameraMaxZoom = nil
local _wasUIVisible = false
local _savedMouseBehavior = Enum.MouseBehavior.Default

SafeConnect(RunService.RenderStepped, function()
    if ghostOn then return end
    local isVisible = TargetGui and TargetGui.Parent and TargetGui.Enabled
    if isVisible then
        if not _wasUIVisible then
            _wasUIVisible = true
            _savedMouseBehavior = UserInputService.MouseBehavior
            _savedMouseIcon = UserInputService.MouseIconEnabled
            _savedCameraMinZoom = LocalPlayer.CameraMinZoomDistance
            _savedCameraMaxZoom = LocalPlayer.CameraMaxZoomDistance
        end
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        UserInputService.MouseIconEnabled = true
        if LocalPlayer.CameraMinZoomDistance < 0.5 then
            LocalPlayer.CameraMinZoomDistance = 0.5
        end
        if Camera and Camera.CFrame then
            local char = LocalPlayer.Character
            if char then
                local head = char:FindFirstChild("Head")
                if head then
                    local dist = (Camera.CFrame.Position - head.Position).Magnitude
                    if dist < 1 then
                        LocalPlayer.CameraMinZoomDistance = 4
                        LocalPlayer.CameraMaxZoomDistance = math.max(LocalPlayer.CameraMaxZoomDistance, 20)
                    end
                end
            end
        end
    else
        if _wasUIVisible then
            _wasUIVisible = false
            UserInputService.MouseIconEnabled = _savedMouseIcon
            if _savedCameraMinZoom then
                LocalPlayer.CameraMinZoomDistance = _savedCameraMinZoom
            end
            if _savedCameraMaxZoom then
                LocalPlayer.CameraMaxZoomDistance = _savedCameraMaxZoom
            end
        end
    end
end)

