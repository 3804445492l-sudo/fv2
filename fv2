    local ghostOn = false local gPos = Vector3.new() local gRot = Vector2.new()
    local function ToggleGhost()
        ghostOn = not ghostOn
        if ghostOn then
            local cf = Camera.CFrame gPos = cf.Position local rx, ry = cf:ToEulerAnglesYXZ() gRot = Vector2.new(math.deg(rx), math.deg(ry))
            local _, r = GetCharParts() if r then r.Anchored = true end
            RunService:BindToRenderStep("FGGhost", Enum.RenderPriority.Camera.Value + 100, function() pcall(function()
                Camera.CameraType = Enum.CameraType.Scriptable UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
                local d = UserInputService:GetMouseDelta() gRot = gRot - Vector2.new(d.Y, d.X) * 0.4 gRot = Vector2.new(math.clamp(gRot.X, -89, 89), gRot.Y)
                local rcf = CFrame.fromEulerAnglesYXZ(math.rad(gRot.X), math.rad(gRot.Y), 0) local inp = Vector3.zero
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then inp = inp + Vector3.new(0, 0, -1) end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then inp = inp + Vector3.new(0, 0, 1) end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then inp = inp + Vector3.new(-1, 0, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then inp = inp + Vector3.new(1, 0, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.E) then inp = inp + Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.Q) then inp = inp + Vector3.new(0, -1, 0) end
                local spd = 1 if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then spd = 3 end
                if inp.Magnitude > 0 then gPos = gPos + (rcf:VectorToWorldSpace(inp.Unit) * spd) end
                Camera.CFrame = CFrame.new(gPos) * rcf
            end) end)
            ContextActionService:BindActionAtPriority("FGInput", function() return Enum.ContextActionResult.Sink end, false, 20000, Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S, Enum.KeyCode.D, Enum.KeyCode.Space)
            Library:Notify("👻 自由视角开启", 3)
        else
            pcall(function() RunService:UnbindFromRenderStep("FGGhost") end) pcall(function() ContextActionService:UnbindAction("FGInput") end)
            local _, r, h = GetCharParts() if r then r.Anchored = false end Camera.CameraType = Enum.CameraType.Custom if h then Camera.CameraSubject = h end UserInputService.MouseBehavior = Enum.MouseBehavior.Default
            Library:Notify("👻 自由视角关闭", 2)
        end
    end
