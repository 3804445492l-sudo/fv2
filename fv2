    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and not playerChars[obj] and obj ~= myChar then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum then
                table.insert(result, obj)
            end
        end
