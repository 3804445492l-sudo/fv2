local function FindAimPart(model)
    local p = model:FindFirstChild(AimPartName)
    if p and p:IsA("BasePart") then return p end
    for _, n in ipairs({"Head", "HumanoidRootPart", "UpperTorso", "Torso"}) do
        local f = model:FindFirstChild(n)
        if f and f:IsA("BasePart") then return f end
    end
    return nil
end

local function IsAimValid(model)
    if not model or not model.Parent then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    local part = FindAimPart(model)
    if not part then return false end
    local _, myRoot = GetCharParts()
    if not myRoot then return false end
    if (part.Position - myRoot.Position).Magnitude > AimMaxDistValue then return false end
    return true
end

local function GetAimTargets()
    local res = {}
    -- 玩家
    for _, pl in pairs(Players:GetPlayers()) do
        if pl ~= LocalPlayer and pl.Character then
            local c = pl.Character
            local hum = c:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local part = FindAimPart(c)
                if part and not (AimTeamCheckEnabled and LocalPlayer.Team and pl.Team == LocalPlayer.Team) then
                    table.insert(res, {model = c, name = pl.Name, part = part})
                end
            end
        end
    end
    -- NPC (使用缓存)
    if tick() - _npcCacheTime > NPC_CACHE_INTERVAL then
        RefreshNPCCache()
    end
    for _, obj in ipairs(_npcCache) do
        if obj and obj.Parent then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local part = FindAimPart(obj)
                if part then
                    table.insert(res, {model = obj, name = obj.Name, part = part})
                end
            end
        end
    end
    return res
end

SafeConnect(RunService.RenderStepped, function(dt)
    if not AimEnabled then
        _G._AimLocked = nil
        aimPrevName = nil
        return
    end
    if ghostOn then return end

    local aiming = (AimKeyMode == "Always") and true or AimKeyActive
    if not aiming then
        if not AimStickyLockEnabled then
            _G._AimLocked = nil
            aimPrevName = nil
        end
        return
    end

    local _, myRoot = GetCharParts()
    if not myRoot then return end

    if _G._AimLocked and not IsAimValid(_G._AimLocked) then
        _G._AimLocked = nil
        aimPrevName = nil
    end

    if not _G._AimLocked then
        local targets = GetAimTargets()
        local best, bScore, bName = nil, math.huge, ""
        local sc = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

        for _, d in ipairs(targets) do
            local part = d.part
            if not part or not part.Parent then continue end
            local wDist = (part.Position - myRoot.Position).Magnitude
            if wDist > AimMaxDistValue then continue end

            if AimPriorityValue == "离我最近" then
                if wDist < AimFovValue and wDist < bScore then
                    bScore = wDist
                    best = d.model
                    bName = d.name
                end
            else
                local sPos, onS = Camera:WorldToViewportPoint(part.Position)
                if onS then
                    local sDist = (Vector2.new(sPos.X, sPos.Y) - sc).Magnitude
                    if sDist < bScore then
                        bScore = sDist
                        best = d.model
                        bName = d.name
                    end
                end
            end
        end

        if best then
            _G._AimLocked = best
            if bName ~= aimPrevName and AimNotifyEnabled then
                WindUI:Notify({Title = "自瞄", Content = "锁定: " .. bName, Duration = 2})
            end
            aimPrevName = bName
        end
    end

    if not _G._AimLocked then return end
    local part = FindAimPart(_G._AimLocked)
    if not part then
        _G._AimLocked = nil
        aimPrevName = nil
        return
    end

    local aimPos = part.Position
    if AimPredValue > 0 then
        local bRoot = _G._AimLocked:FindFirstChild("HumanoidRootPart")
        local vel = bRoot and bRoot.AssemblyLinearVelocity or part.AssemblyLinearVelocity
        if vel and vel.Magnitude > 0.1 then
            aimPos = aimPos + vel * (AimPredValue / 100)
        end
    end

    local camPos = Camera.CFrame.Position
    local dist = (aimPos - camPos).Magnitude
    if dist > 0.01 then
        local targetCF = CFrame.lookAt(camPos, aimPos)
        local alpha = math.clamp(1 / AimSmoothValue, 0.01, 1)
        Camera.CFrame = Camera.CFrame:Lerp(targetCF, alpha)
    end
end)

